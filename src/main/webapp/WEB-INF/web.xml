<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

    <display-name>onlinebookstore</display-name>

  <welcome-file-list>
    <welcome-file>HomePage.jsp</welcome-file>
</welcome-file-list>


    <servlet>
        <servlet-name>UserRegistrationServlet</servlet-name>
        <servlet-class>cscorner.UserRegistrationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserRegistrationServlet</servlet-name>
        <url-pattern>/UserRegistrationServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminRegistrationServlet</servlet-name>
        <servlet-class>cscorner.AdminRegistrationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminRegistrationServlet</servlet-name>
        <url-pattern>/AdminRegistrationServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>Signinvalidation</servlet-name>
        <servlet-class>cscorner.Signinvalidation</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Signinvalidation</servlet-name>
        <url-pattern>/Signinvalidation</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>Usersinginvalidation</servlet-name>
        <servlet-class>cscorner.Usersinginvalidation</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Usersinginvalidation</servlet-name>
        <url-pattern>/Usersinginvalidation</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>Uservalidation</servlet-name>
        <servlet-class>cscorner.Uservalidation</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Uservalidation</servlet-name>
        <url-pattern>/Uservalidation</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>Addbook</servlet-name>
        <servlet-class>cscorner.Addbook</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Addbook</servlet-name>
        <url-pattern>/Addbook</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RemoveCart</servlet-name>
        <servlet-class>cscorner.removeCart</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RemoveCart</servlet-name>
        <url-pattern>/RemoveCart</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RetrieveDataServlet</servlet-name>
        <servlet-class>cscorner.RetrieveDataServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RetrieveDataServlet</servlet-name>
        <url-pattern>/RetrieveDataServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RemoveFromCart</servlet-name>
        <servlet-class>cscorner.RemoveFromCart</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RemoveFromCart</servlet-name>
        <url-pattern>/RemoveFromCart</url-pattern>
    </servlet-mapping>

    <jsp-config>
        <taglib>
            <taglib-uri>http://java.sun.com/jsp/jstl/core</taglib-uri>
            <taglib-location>/WEB-INF/lib/jstl-1.2.jar</taglib-location>
        </taglib>
    </jsp-config>

</web-app>
